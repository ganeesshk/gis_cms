# .env
APP_NAME="CMS"
APP_ENV=development
APP_DEBUG=true
APP_URL="http://localhost/cms"
APP_TIMEZONE="UTC"

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cms
DB_USER=cms_app
DB_PASS=ChangeMe123!
DB_CHARSET=utf8

# Security
SECRET_KEY="your-32-character-secret-key-here-change-it"
BCRYPT_COST=12
SESSION_LIFETIME=1800
SESSION_NAME="cms_session"
CSRF_EXPIRY=7200

# Uploads
UPLOAD_MAX_SIZE=10485760
ALLOWED_EXTENSIONS="jpg,jpeg,png,gif,webp"
UPLOAD_PATH="/uploads"
THUMB_PREFIX="thumb_"