# .env.example
APP_NAME="ASI CMS"
APP_ENV=staging
APP_DEBUG=true
APP_URL="http://asi-trichy.gov.in"
APP_TIMEZONE="UTC"

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gsi_cms
DB_USER=postgres
DB_PASS=postgres
DB_CHARSET=utf8

# Security
SECRET_KEY="india is country. all indians al"
BCRYPT_COST=12
SESSION_LIFETIME=1800
SESSION_NAME="cms_session"
CSRF_EXPIRY=7200

# Uploads
UPLOAD_MAX_SIZE=10485760
ALLOWED_EXTENSIONS="jpg,jpeg,png,gif,webp,pdf,doc,docx,mp4,webm"
UPLOAD_PATH="/uploads"
THUMB_PREFIX="thumb_"

# Mail (for password reset)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="CMS System"